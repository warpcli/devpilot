export TOP_HEAD="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"

if ! use nvidia; then
  unset NVIDIA_VERSION
  echo "devpilot: NVIDIA driver not detected; using nixGLIntel/nixVulkanIntel fallback"
fi
use display

use flake --impure --option warn-dirty false

export ENVNAME=nim
unset GITHUB_TOKEN

export PATH="$PATH:$PWD:$PWD/bin:$HOME/.nimble/bin"

export_alias _b "cd $TOP_HEAD && nimble build; cd -"
export_alias _c "cd $TOP_HEAD && nim c -d:release src/dp.nim; cd -"
export_alias _r "cd $TOP_HEAD && nimble run; cd -"
export_alias _t "cd $TOP_HEAD && nimble test; cd -"
